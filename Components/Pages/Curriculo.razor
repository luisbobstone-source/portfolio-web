@page "/meu-curriculo"

<section class="pagina-inicial">

    <section class="secao-banner">
        <div class="banner-principal">
            <p class="subtitulo-banner">02</p>

            <h1 class="titulo-banner">Meu Currículo</h1>

            <p class="texto-banner">
                Aqui estão algumas das minhas principais habilidades e tecnologias
                que venho estudando e desenvolvendo ao longo da minha trajetória
                no ifro.
            </p>
        </div>
    </section>

    <section class="secao-destaques">

        <article class="cartao-destaque cartao-claro">
            <h2>HTML & CSS</h2>

            <p>
                Desenvolvimento de páginas modernas, responsivas e organizadas,
                utilizando boas práticas de estruturação e estilização web.
            </p>
